                <&kp SPACE>;
        };

        m_mute: m_mute {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <20>;
            tap-ms = <20>;
            bindings =
                <&macro_tap>,
                <&kp LS(LC(LA(O)))>,
                <&macro_tap>,
